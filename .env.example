# Copie este arquivo para .env e preencha as chaves.
# Em produção (Render), estas mesmas variáveis vão no painel do serviço.

# Anthropic (obrigatória) — https://platform.claude.com/ -> API Keys
ANTHROPIC_API_KEY=sk-ant-...

# Google (Gmail + Calendar) — https://console.cloud.google.com/
# 1. Crie um projeto; 2. Ative as APIs "Gmail API" e "Google Calendar API";
# 3. Tela de consentimento OAuth (tipo Externo, adicione seu e-mail como testador);
# 4. Credenciais -> Criar credenciais -> ID do cliente OAuth -> Aplicativo da Web;
#    Redirect URIs autorizados (cadastre OS DOIS):
#      http://localhost:3001/api/google/callback
#      https://SEU-APP.onrender.com/api/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Windsor.ai (métricas Instagram/YouTube + anúncios Meta) — https://onboard.windsor.ai/
WINDSOR_API_KEY=

# Instagram / Meta (automação comentário -> DM)
META_WEBHOOK_VERIFY_TOKEN=
META_APP_SECRET=
IG_ACCESS_TOKEN=
IG_USER_ID=

# Supabase (armazenamento em produção) — painel do projeto -> Settings -> API
# SUPABASE_URL: "Project URL"   |   SUPABASE_SERVICE_KEY: a chave "service_role"
# Se ambas ficarem vazias, o VEDO usa arquivos locais em data/ (modo dev).
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Login do painel (produção) — sem VEDO_SENHA, o painel fica aberto (ok só local)
VEDO_SENHA=
# Segredo da sessão (opcional): qualquer string aleatória longa
VEDO_SESSION_SECRET=

# URL pública do serviço (produção) — ex.: https://SEU-APP.onrender.com
# Define o redirect do Google e marca o cookie de sessão como Secure.
PUBLIC_URL=
